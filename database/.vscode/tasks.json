{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Linux",
            "command": "/usr/bin/g++",
            "args": [
                "-ggdb",
                "-std=c++23",
                "${workspaceFolder}/Main.cpp",
                "-Wterminate",
                "-o",
                "${workspaceFolder}/out/linux/Main",
                "-lutilsJPL"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "cppbuild",
            "label": "Windows",
            "command": "g++",
            "args": [
                "-g",
                "-std=c++23",
                "-DUSE_LOGGER_JPL",
                "${workspaceFolder}/Main.cpp",
                "${workspaceFolder}/src/DBConnection.cpp",
                "${workspaceFolder}/src/ModelWrapper.cpp",
                "${workspaceFolder}/src/query/Query.cpp",
                "${workspaceFolder}/src/query/QueryCompiler.cpp",
                "-lutilsJPL",
                "-lloggerJPL",
                "-lutilsJPL",
                "-lsqlapi",
                "-o",
                "${workspaceFolder}/out/windows/Main.exe",
                "-lversion" //Needed by sqlqpi
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "Start GDBServer x WIN",
            "isBackground": true,
            "command": "/usr/x86_64-w64-mingw32/sys-root/mingw/bin/gdbserver.exe",
            "args": [
                ":1234",
                "${workspaceFolder}/out/windows/Main.exe"
            ],
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": ".",
                            "file": 1,
                            "location": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": ".",
                        "endsPattern": "."
                    }
                }
            ]
        }
    ],
    "version": "2.0.0"
}