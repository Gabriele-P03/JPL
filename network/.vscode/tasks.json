{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Linux",
            "command": "/usr/bin/g++",
            "args": [
                "-ggdb",
                "-std=c++23",
                "${workspaceFolder}/Main.cpp",
                "-Wterminate",
                "-o",
                "${workspaceFolder}/out/linux/Main",
                "-lutilsJPL"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "cppbuild",
            "label": "Windows Client",
            "command": "g++",
            "args": [
                "-g",
                "-std=c++23",
                "${workspaceFolder}/MainClient.cpp",
                "${workspaceFolder}/src/socket/AbstractSocket.cpp",
                "${workspaceFolder}/src/socket/ClientSocket.cpp",
                "${workspaceFolder}/src/tls/TLS.cpp",
                "${workspaceFolder}/src/tls/TLSWrapper.cpp",
                "${workspaceFolder}/src/http/Response.cpp",
                "${workspaceFolder}/src/http/HttpClient.cpp",
                "${workspaceFolder}/src/http/HttpClientAbstract.cpp",
                "-lws2_32",
                "-lcurl",
                "-lssl",
                "-lutilsJPL",
                "-lloggerJPL",
                "-lutilsJPL",
                "-ldbghelp",
                "-lPowrProf",
                "-lpdh",
                "-lcrypto",
                "-o",
                "${workspaceFolder}/out/windows/MainClient.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "cppbuild",
            "label": "Windows Server",
            "command": "g++",
            "args": [
                "-g",
                "-std=c++23",
                "-DUSE_LOGGER_JPL",
                "${workspaceFolder}/MainServer.cpp",
                "${workspaceFolder}/src/socket/AbstractSocket.cpp",
                "${workspaceFolder}/src/socket/ServerSocket.cpp",
                "${workspaceFolder}/src/tls/TLS.cpp",
                "${workspaceFolder}/src/tls/TLSWrapper.cpp",
                "${workspaceFolder}/src/socket/clientmanager/Client.cpp",
                "${workspaceFolder}/src/socket/clientmanager/ClientManager.cpp",
                "-lws2_32",
                "-lssl",
                "-lutilsJPL",
                "-lloggerJPL",
                "-lutilsJPL",
                "-ldbghelp",
                "-lPowrProf",
                "-lpdh",
                "-lcrypto",
                "-o",
                "${workspaceFolder}/out/windows/MainServer.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "Start GDBServer x WIN",
            "isBackground": true,
            "command": "/usr/x86_64-w64-mingw32/sys-root/mingw/bin/gdbserver.exe",
            "args": [
                ":1234",
                "${workspaceFolder}/out/windows/Main.exe"
            ],
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": ".",
                            "file": 1,
                            "location": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": ".",
                        "endsPattern": "."
                    }
                }
            ]
        }
    ],
    "version": "2.0.0"
}